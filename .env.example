# Render PostgreSQL Internal Database URL
DATABASE_URL=postgresql://user:password@host:5432/ailife_db
PGSSLMODE=disable

# Auth
AUTH_SECRET=replace-with-a-long-random-secret
ENABLE_2FA=true
DEFAULT_TOTP_SECRET=

# Notifications
TERMII_API_KEY=
RESEND_API_KEY=
FROM_EMAIL=alerts@ailifeempowerment.com

NEXT_PUBLIC_APP_NAME=AILIFE Empowerment
NEXT_PUBLIC_SITE_URL=https://ailifeempowerment.com
